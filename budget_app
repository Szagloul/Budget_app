class Category:
    def __init__(self,name):
        self.name = name
        self.ledger = []

    def deposit(self,amount,description = ''):
        self.ledger.append({'amount': amount, 'description': description})

    def withdraw(self, amount, description=''):
        if self.check_funds(amount):
            self.ledger.append({'amount': -amount, 'description': description})
            return True
        else:
            return False

    def get_balance(self):
        total = 0
        for entry in self.ledger:
            total+= entry['amount']
        return total

    def transfer(self, amount, destination):
        if self.check_funds(amount):
            self.withdraw(amount, f"Transfer to {destination.name}")
            destination.deposit(amount, f"Transfer from {self.name}")
            return True
        return False
        
    def check_funds(self,amount):
        if amount > self.get_balance():
            return False
        return True
    def __str__(self):
        title = f"{self.name:*^30}\n"
        items = ""
        for entry in self.ledger:
            amount = f"{entry['amount']:.2f}"
            description = entry['description'][:23]
            items += f"{description:<23}{amount:>7}\n"
        total = f"Total: {self.get_balance():.2f}"
        return title + items + total
    

def create_spend_chart(categories):
    chart = "Percentage spent by category\n"

    category_spent = []
    total_spent = 0
    for cat in categories:
        spent = sum(-entry['amount'] for entry in cat.ledger if entry['amount'] < 0)
        category_spent.append(spent)
        total_spent += spent

    percentages = [int(spent / total_spent * 100) // 10 * 10 for spent in category_spent]

    
    for i in range(100, -1, -10):
        chart += str(i).rjust(3) + '|'
        for perc in percentages:
            chart += " o " if perc >= i else "   "
        chart += " \n"

    
    chart += "    " + "---" * len(categories) + "-\n"

    
    max_len = max(len(cat.name) for cat in categories)
    for i in range(max_len):
        chart += "    "
        for cat in categories:
            chart += " " + cat.name[i] + " " if i < len(cat.name) else "   "
        chart += " \n"

    return chart.rstrip("\n")
categories =[]
while True:
    
    print("\nOptions: ")
    print("1 - Add a new category")
    print("2 - Select an existing category")
    print("3 - Show spend chart")
    print("4 - Quit")

    choice = input("Enter your choice: ")
    if choice == '1':
        name = input("Enter category name: ")
        category = Category(name)
        categories.append(category)
        print(f"Category '{name}' created.")
    elif choice == '2':
        if not categories:
            print("No categories available. Please add a category first.")
            continue
        print("Available categories:")
        for i, cat in enumerate(categories):
            print(f"{i + 1} - {cat.name}")
        cat_choice = int(input("Select a category by number: ")) - 1
        if 0 <= cat_choice < len(categories):
            selected_cat = categories[cat_choice]
            while True:
                print(f"\nSelected Category: {selected_cat.name}")
                print("Options: ")
                print("1 - Deposit")
                print("2 - Withdraw")
                print("3 - Transfer")
                print("4 - Check Balance")
                print("5 - Show Ledger")
                print("6 - Back to main menu")

                cat_action = input("Enter your choice: ")
                if cat_action == '1':
                    amount = float(input("Enter deposit amount: "))
                    description = input("Enter description (optional): ")
                    selected_cat.deposit(amount, description)
                    print("Deposit successful.")
                elif cat_action == '2':
                    amount = float(input("Enter withdrawal amount: "))
                    description = input("Enter description (optional): ")
                    if selected_cat.withdraw(amount, description):
                        print("Withdrawal successful.")
                    else:
                        print("Insufficient funds.")
                elif cat_action == '3':
                    if len(categories) < 2:
                        print("Not enough categories to transfer.")
                        continue
                    print("Available categories to transfer to:")
                    for i, cat in enumerate(categories):
                        if cat != selected_cat:
                            print(f"{i + 1} - {cat.name}")
                    dest_choice = int(input("Select a category by number: ")) - 1
                    if 0 <= dest_choice < len(categories) and categories[dest_choice] != selected_cat:
                        dest_cat = categories[dest_choice]
                        amount = float(input("Enter transfer amount: "))
                        if selected_cat.transfer(amount, dest_cat):
                            print("Transfer successful.")
                        else:
                            print("Insufficient funds.")
                    else:
                        print("Invalid category selection.")
                elif cat_action == '4':
                    balance = selected_cat.get_balance()
                    print(f"Current balance: {balance:.2f}")
                elif cat_action == '5':
                    print(selected_cat)
                elif cat_action == '6':
                    break
                else:
                    print("Invalid choice. Please try again.")
        else:
            print("Invalid category selection.")

    elif choice == '3':
        if categories:
            print(create_spend_chart(categories))
            continue
        else: print("No categories available. Please add one first.")
    elif choice == '4':
        print("Goodbye!")
        break